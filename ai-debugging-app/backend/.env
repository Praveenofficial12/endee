# ──────────────────────────────────────────────
#  AI Debugging Assistant — Environment Variables
# ──────────────────────────────────────────────

# OpenAI API Key (required for LLM-powered analysis)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM model to use (default: gpt-3.5-turbo)
LLM_MODEL=gpt-3.5-turbo

# Endee Vector Database URL
# Default: http://localhost:8080/api/v1  (local Docker instance)
ENDEE_URL=http://localhost:8080/api/v1

# Endee Auth Token (leave empty if running without authentication)
ENDEE_AUTH_TOKEN=
